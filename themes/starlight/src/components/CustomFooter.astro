---
import Default from '@astrojs/starlight/components/Footer.astro';
import type { Props } from '@astrojs/starlight/props';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Read graph.json from public/ at SSR/build time
let graphData: any = { backlinks: {} };
try {
  const raw = readFileSync(resolve(process.cwd(), 'public/graph.json'), 'utf-8');
  graphData = JSON.parse(raw);
} catch { /* graph.json not yet generated — silently skip */ }

const currentPath = Astro.url.pathname;
const allBacklinks = graphData.backlinks || {};

// Normalize to prevent trailing slash mismatch
const normalizePath = (p: string) => (() => {
	const replaced = p.replace(/\/$/, '');
	return replaced === '' ? '/' : replaced;
})();
const normalizedCurrent = normalizePath(currentPath);

const backlinksForPage = Object.keys(allBacklinks).reduce((acc, key) => {
	if (normalizePath(key) === normalizedCurrent) {
		return acc.concat(allBacklinks[key as keyof typeof allBacklinks]);
	}
	return acc;
}, [] as { url: string; title: string }[]);

const isEnglish = currentPath.startsWith('/en/');
const uiTitle = isEnglish ? "Backlinks" : "漫游关联";
---

{backlinksForPage.length > 0 && (
<div class="garden-backlinks">
	<h3><span class="icon">🌱</span> {uiTitle} <span class="count">({backlinksForPage.length})</span></h3>
	<ul class="backlink-list">
		{backlinksForPage.map((link) => (
			<li>
				<a href={link.url} class="backlink-card">
					<span class="link-title">{link.title}</span>
					<span class="sl-icon">↗</span>
				</a>
			</li>
		))}
	</ul>
</div>
)}

<!-- 先渲染 Starlight 原生的翻页器和编辑链接 -->
<Default {...Astro.props} />

<!-- 然后追加我们自己极其克制的版权行 -->
<div class="custom-global-footer">
	<p>Powered by <a href="https://github.com/Illacme/illacme-plenipes" target="_blank">Illacme-plenipes</a></p>
</div>

<style>
.garden-backlinks {
	margin-top: 3rem;
	margin-bottom: 2rem;
	padding: 1.5rem;
	background: var(--sl-color-gray-6);
	border: 1px solid var(--sl-color-gray-5);
	border-radius: 0.75rem;
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.garden-backlinks h3 {
	font-size: 1.2rem;
	margin-top: 0;
	margin-bottom: 1rem;
	color: var(--sl-color-white);
	display: flex;
	align-items: center;
	gap: 0.5rem;
}

.garden-backlinks .count {
	font-size: 0.9rem;
	color: var(--sl-color-gray-3);
	font-weight: normal;
}

.backlink-list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
	gap: 1rem;
}

.backlink-card {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 0.75rem 1rem;
	background: var(--sl-color-black);
	border: 1px solid var(--sl-color-gray-5);
	border-radius: 0.5rem;
	text-decoration: none !important;
	color: var(--sl-color-text) !important;
	transition: all 0.2s ease-in-out;
}

.backlink-card:hover {
	border-color: var(--sl-color-accent);
	background: var(--sl-color-gray-6);
	transform: translateY(-2px);
	box-shadow: 0 4px 12px rgba(var(--sl-color-accent), 0.2);
}

.backlink-card .link-title {
	font-weight: 500;
	line-height: 1.4;
}

.backlink-card .sl-icon {
	color: var(--sl-color-gray-4);
	font-size: 0.8em;
	transition: color 0.2s;
	margin-left: 0.5rem;
}

.backlink-card:hover .sl-icon {
	color: var(--sl-color-accent);
}

.custom-global-footer {
	margin-top: 2rem;
	text-align: center;
}
.custom-global-footer p {
	font-size: 0.8rem;
	color: var(--sl-color-gray-3);
}
.custom-global-footer a {
	color: var(--sl-color-text-accent);
	text-decoration: none;
}
</style>
