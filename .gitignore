# ============================================================
# Illacme Plenipes - Global Private Press Governance Rules
# ============================================================

# 🛡️ [V35.0] 物理主权红线 (Physical Sovereignty Boundaries)
.plenipes/*
!.plenipes/rules.md
!.plenipes/governance/

# 🔒 主权出版社空间（绝对禁止外泄）
workspace/

# 🔒 原始稿件库
content-vault/

# 🔒 物理账本（全量屏蔽）
*.db

# 🔒 终极密钥（绝对禁止外泄）
**/.master.key
*.local.yaml
*.local.yml
config.local.yaml

# 📦 依赖与环境
node_modules/
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.env
.DS_Store

# 📊 付印产物与影子库 (Production & Shadows)
dist/
build/
.docusaurus/
.astro/
cache/
**/cache/
themes/*/dist/
themes/*/public/assets/
themes/*/.temp/

# 排除各主题下生成的稿件副本（仅保留模板）
themes/*/src/content/docs/*
!themes/*/src/content/docs/index.md
!themes/*/src/content/docs/readme.md

# 🛡️ 审计与日志
*.log
logs/
.coverage
htmlcov/
.pytest_cache/
scripts/*.tmp
dashboard/public/data/engine_pulse_*.json

# 🚀 临时资产与自愈脚本
scratch/
diagnose_assets.py
compliance_sentry.py
banner_*.txt
test_*.md
temp_*.py
data/

# 🌌 动态状态与系统生成资产 (Runtime & Generated)
territories/
manuscripts/
